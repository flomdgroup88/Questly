rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Личные данные пользователя ────────────────────────────────
    // Telegram-пользователи: ключ "tg_{id}" — без серверной проверки
    // Firebase anonymous: правило по request.auth.uid
    match /userData/{userKey} {
      // Telegram-ключи: доступ открыт (ID известен только владельцу аккаунта)
      allow read, write: if userKey.matches('tg_.*');
      // Anonymous auth: только владелец
      allow read, write: if request.auth != null && request.auth.uid == userKey;
    }

    // ── Соцфичи (без аутентификации — Telegram Mini App) ─────────
    match /challenges/{shareCode} {
      allow read, write: if true;
    }

    match /sharedGoals/{shareCode} {
      allow read, write: if true;
    }
  }
}
